DATABASE_HOST=
DATABASE_PORT=
DATABASE_USER=
DATABASE_PASSWORD=
DATABASE_DB=

RABBITMQ_USER=
RABBITMQ_PASS=
RABBITMQ_HOST=
RABBITMQ_PORT=

HTTP_PORT=

RSS_POLL_INTERVAL=15m

WEBHOOK_SECRET=

DIGEST_RECIPIENT_EMAIL=
DIGEST_SCHEDULE=
DIGEST_MAX_ARTICLES=
DIGEST_LOOKBACK_HOURS=

# Public origin used to build absolute headline links in the digest email
# ({base}/r/{article-id}). Defaults to http://localhost:8080.
#
# In production this is the tunnel's *read* hostname (e.g. https://read.example.com),
# NOT the hostname the email Worker POSTs /webhook/email to — those are two
# separate public hostnames on the same tunnel. See docs/adr/0001.
# No trailing slash: the template appends "/r/{id}" directly.
#
# Leave blank for local dev. Blank falls back to the default above, and the
# digest then renders a warning banner instead of mailing dead links.
PUBLIC_BASE_URL=

# Cloudflare Workers AI model. Use an instruct model, not a code model — the
# provider does summarization/categorization/scoring, not code generation.
# Defaults to @cf/google/gemma-4-26b-a4b-it.
AI_MODEL=

# Bounds a single Cloudflare AI call. Digest compute makes several calls back
# to back (categorize/summarize/digest) under one overall budget, so this caps
# how much of that budget one slow call can consume. Defaults to 30s.
AI_REQUEST_TIMEOUT=

# How much article body Score/Categorize/Reason feed the model, in characters.
# Defaults to 8000.
AI_MAX_CONTENT_CHARS=

# Local dev: use Mailpit
SMTP_HOST=
SMTP_PORT=
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_NAME=
SMTP_FROM_MAIL=

# Periodic OPML backup of Sources, emailed to yourself. Defaults to weekly
# (Sun 03:00) if unset. Backup is skipped (logged, not an error) if
# BACKUP_RECIPIENT_EMAIL is blank.
BACKUP_RECIPIENT_EMAIL=
BACKUP_SCHEDULE=

# Article content fetching (Phase 17 — fetches the real page behind an RSS
# item's link, instead of trusting the feed's <description> teaser).
# Bounds a single article-page fetch. Defaults to 15s.
FETCH_TIMEOUT=
# Caps how much of a response body is read, in bytes. Defaults to 5242880 (5MB).
FETCH_MAX_BYTES=
# Quality-gate floor: extracted plain text shorter than this (in characters)
# is treated as a failed fetch (consent wall/SPA shell/paywall) and the
# article falls back to feed content. Defaults to 500.
FETCH_MIN_CONTENT_CHARS=
# Identifies the fetcher truthfully — no browser-UA spoofing.
FETCH_USER_AGENT=
# Caps the algorithmic distillation pass that produces distilled_content, in
# characters. Defaults to 2000.
DISTILL_MAX_CHARS=
